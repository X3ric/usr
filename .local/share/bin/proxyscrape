                "ZM") country+="🇿🇲";;
                "ZW") country+="🇿🇼";;
                *) country+="🌐";;
            esac
        fi
        local type=$(echo "$prefix" | cut -d':' -f1)
        local results="$HOME/.cache/$type.txt"
        [[ ! -f $results ]] && touch $results
        [[ ! -f "$HOME/.cache/proxylist.txt" ]] && touch "$HOME/.cache/proxylist.txt"
        if ! grep -qF "$ip:$port" "$results" && [[ ! -z $country ]] ; then
            echo "$ip:$port" >> "$HOME/.cache/proxylist.txt"
            echo "$ip:$port" >> "$results"
            if [ -z "$speed" ]; then
                speed=0
            fi
            echo -e "$(printf '\033[1;38m%-12s\033[0m' "$(echo $(< "/tmp/proxy-counter.txt")/${proxies})") $(printf '\033[1;34m%-21s\033[0m' "$ip:$port") $(printf '\033[1;32m%-8s\033[0m' "$country") $(printf '\033[1;31m%-10s\033[0m' "Speed[$speed]") \033[1;36mSaved in $results\033[0m \033[1;37mFinded $(wc --lines < $HOME/.cache/proxylist.txt | awk '{print $1}')\033[0m"
