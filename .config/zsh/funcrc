    echo "Downloading audio with embedded thumbnail..."
    yt-dlp --embed-thumbnail --extract-audio --audio-format mp3 --ignore-config --yes-playlist --no-part --no-warnings -o "%(title)s.%(ext)s" "$link"
    echo "Done!"
}
