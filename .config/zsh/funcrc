    local path
    if [ -z "$@" ]; then
        path=$(pwd)
    else
        path=$1
    fi
    if [ -e "$path" ]; then
        echo -e "$path\n" >> "$CacheFile"
        echo "Added '$path' to bookmarks."
    else
        echo "Error: '$path' does not exist."
    fi
